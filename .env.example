# ─── Server ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ────────────────────────────────────
# API Key to authenticate requests to the microservice
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=your_secret_api_key_min_32_chars

# ─── Email ───────────────────────────────────────
# true = uses Ethereal (test emails, no real account needed)
# false = uses Gmail with the credentials below
EMAIL_TEST_MODE=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=Mail Service
EMAIL_BRAND_LOGO=https://example.com/logo.png

# ─── Frontend ────────────────────────────────────
# Base URL to build links inside emails
FRONTEND_URL=http://localhost:5173

# ─── Database (for delivery logs) ───────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=letterbox_email
DB_USER=postgres
DB_PASSWORD=your_password
